# Скопируй этот файл в .env и заполни значения
# cp .env.example .env

# OpenAI API ключ для VLM-оценки зданий (GPT-4o)
# Получить: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Опциональные настройки
VLM_MODEL=bytedance-seed/seed-1.6-flash          # модель для визуальной оценки
VLM_PASS_SCORE=60         # минимальный балл для прохождения (0-100)
